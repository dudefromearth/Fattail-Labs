# FatTail Labs — full config surface. Copy to .env and fill in.
# Every variable here is REQUIRED unless noted; the server refuses to boot without them.

LABS_ENV=dev                          # dev | staging | production
LABS_PORT=4000

# MySQL
LABS_DB_HOST=127.0.0.1
LABS_DB_PORT=3306
LABS_DB_USER=labs
LABS_DB_PASSWORD=change-me
LABS_DB_NAME=labs
# Optional pool size (default 10). Phase E hardening.
#LABS_DB_POOL_SIZE=10

# Phase F — Bunny Stream for gated lesson video (optional until provider=bunny)
#LABS_BUNNY_LIBRARY_ID=
#LABS_BUNNY_TOKEN_KEY=
#LABS_BUNNY_EMBED_HOST=https://iframe.mediadelivery.net
#LABS_VIDEO_SIGNED_TTL_SECONDS=3600

# Phase G — HeyGen production from board (optional until live produce)
# HEYGEN_API_KEY=                    # also used by heygen CLI credentials
# LABS_HEYGEN_DRY_RUN=1              # force dry-run video_package when dry_run omitted
# LABS_CAST_DIR=                     # override docs/studio/cast (tests only)
# LABS_HEYGEN_MAX_BATCH=3            # max renders per produce (G2b)
# LABS_HEYGEN_DAILY_JOB_LIMIT=10     # live jobs/day (G3)
# LABS_HEYGEN_MONTHLY_JOB_LIMIT=100  # live jobs/month (G3)
# LABS_QUEBEC_AUTO=1                 # allow agent board:operate Quebec tick (G4)
# Automatic board poller (Quebec Poller Spec v1.0) — separate process:
#   LABS_QUEBEC_POLLER=1
#   LABS_QUEBEC_POLL_INTERVAL_SECONDS=60
#   LABS_QUEBEC_AUTO_PRODUCE=1
#   LABS_QUEBEC_AUTO_PRODUCE_MODE=fixtures   # fixtures | live | auto
#   LABS_QUEBEC_AUTO_HEYGEN=0
#   LABS_QUEBEC_MAX_ACTIONS=20
#   .venv/bin/python quebec_poller.py

# Dual-issuer WordPress SSO — secrets shared with WP fotw-sso plugin
# (same values as MarketSwarm-Canonical SSO_FOTW_SECRET / SSO_0DTE_SECRET).
# Source of truth: MarketSwarm-Canonical + fotw-sso. Guide:
# docs/WooCommerce-SSO-Integration-Guide.md
LABS_SSO_SECRET_FATTAIL=change-me     # JWT iss=fotw|fattail  (≥32 chars)
LABS_SSO_SECRET_0DTE=change-me        # JWT iss=0-dte

# Session JWT
LABS_SESSION_SECRET=change-me
LABS_SESSION_TTL_SECONDS=604800       # 7 days
LABS_COOKIE_DOMAIN=                   # empty in dev; .fattail.ai in staging/production

# Optional: SSO buttons. Unset -> button not rendered.
# Same pattern as MSC LoginPage: WP /fotw-sso?redirect=<urlencoded Labs callback>
# Labs callback: https://labs.fattail.ai/api/auth/sso/wordpress:fattail  (plugin appends ?sso=)
# Entitlement mapping is DATA (plans + provider_plan_map), not env.
#LABS_SSO_LOGIN_URL_FATTAIL=https://fattail.ai/fotw-sso?redirect=https%3A%2F%2Flabs.fattail.ai%2Fapi%2Fauth%2Fsso%2Fwordpress%3Afattail
#LABS_SSO_LOGIN_URL_0DTE=https://0-dte.com/fotw-sso?redirect=https%3A%2F%2Flabs.fattail.ai%2Fapi%2Fauth%2Fsso%2Fwordpress%3A0-dte

# Optional: admin notification email (FatTail Hostinger outbound)
# In-app + browser alerts work without this; email_status=skipped until set.
# Hostinger: https://www.hostinger.com/support/4305847-set-up-hostinger-email-on-your-applications-and-devices/
LABS_SMTP_HOST=smtp.hostinger.com
LABS_SMTP_PORT=465
LABS_SMTP_MODE=ssl
# Alternate if 465 fails: PORT=587 MODE=starttls
LABS_SMTP_FROM=labs@fattail.ai
LABS_SMTP_USER=labs@fattail.ai
LABS_SMTP_PASSWORD=change-me
# LABS_NOTIFY_EMAIL_REQUIRED=1
# Absolute links in mail (also used by billing + password-reset emails):
# LABS_WEB_ORIGIN=https://labs.fattail.ai
# LABS_PASSWORD_RESET_TTL_SECONDS=3600   # forgot-password link lifetime (300–86400)
