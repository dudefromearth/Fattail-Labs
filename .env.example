# FatTail Labs — full config surface. Copy to .env and fill in.
# Every variable here is REQUIRED unless noted; the server refuses to boot without them.

LABS_ENV=dev                          # dev | staging | production
LABS_PORT=4000

# MySQL
LABS_DB_HOST=127.0.0.1
LABS_DB_PORT=3306
LABS_DB_USER=labs
LABS_DB_PASSWORD=change-me
LABS_DB_NAME=labs

# Dual-issuer WordPress SSO (HS256 secrets shared with each WP site's SSO plugin)
LABS_SSO_SECRET_FATTAIL=change-me
LABS_SSO_SECRET_0DTE=change-me

# Session JWT
LABS_SESSION_SECRET=change-me
LABS_SESSION_TTL_SECONDS=604800       # 7 days
LABS_COOKIE_DOMAIN=                   # empty in dev; .fattail.ai in staging/production

# WooCommerce plan slug -> Labs role, per issuer (comma-separated issuer:slug=role)
LABS_ENTITLEMENTS=fattail:labs-membership=activator,0-dte:coaching=navigator
